{
  "name": "halogig-backend",
  "version": "2.0.0",
  "description": "HaloGig Backend API - Restructured",
  "main": "index.js",
  "scripts": {
    "start": "nodemon --exec \"npx babel-node src/index.js\"",
    "build": "babel src --out-dir dist --copy-files",
    "serve": "node dist/index.js",
    "lint": "eslint . --fix",
    "migration": "npx sequelize-cli db:migrate",
    "migration:undo": "npx sequelize-cli db:migrate:undo",
    "migration:undo:all": "npx sequelize-cli db:migrate:undo:all",
    "seed": "npx sequelize-cli db:seed:all",
    "seed:undo": "npx sequelize-cli db:seed:undo:all"
  },
  "author": "HaloGig",
  "license": "ISC",
  "dependencies": {
    "@babel/cli": "^7.18.10",
    "@babel/core": "^7.19.1",
    "@babel/node": "^7.19.1",
    "@babel/preset-env": "^7.19.1",
    "@babel/register": "7.18.9",
    "@joi/date": "2.1.0",
    "@sendgrid/mail": "7.7.0",
    "async": "3.2.4",
    "aws-cloudfront-sign": "1.1.0",
    "aws-sdk": "2.1222.0",
    "axios": "^0.27.2",
    "bcryptjs": "2.4.3",
    "compression": "1.7.4",
    "cors": "^2.8.5",
    "dotenv": "16.0.2",
    "easyinvoice": "2.3.3",
    "ejs": "3.1.8",
    "express": "4.18.1",
    "firebase-admin": "11.0.1",
    "google-auth-library": "8.5.2",
    "googleapis": "^171.4.0",
    "helmet": "6.0.0",
    "http-status": "1.5.3",
    "joi": "17.6.1",
    "jsonwebtoken": "8.5.1",
    "lodash": "^4.17.21",
    "method-override": "3.0.0",
    "moment": "2.29.4",
    "moment-timezone": "0.5.37",
    "multer": "^1.4.5-lts.1",
    "multer-s3": "3.0.1",
    "multer-s3-transform": "^2.3.2",
    "mysql2": "2.3.3",
    "node-schedule": "^2.1.0",
    "nodemailer": "6.7.8",
    "paytmchecksum": "^1.5.0",
    "rate-limiter-flexible": "2.3.10",
    "razorpay": "^2.9.2",
    "semver": "7.3.7",
    "sequelize": "6.23.1",
    "socket.io": "^4.7.4",
    "stripe": "10.11.0",
    "swagger-jsdoc": "6.2.5",
    "swagger-ui-express": "4.5.0",
    "twilio": "3.82.1",
    "twitter-api-v2": "^1.29.0",
    "uuid": "^9.0.0",
    "verify-apple-id-token": "3.0.0",
    "winston": "3.8.2",
    "winston-daily-rotate-file": "4.7.1",
    "xlsx": "0.18.5"
  },
  "devDependencies": {
    "eslint": "8.24.0",
    "eslint-config-airbnb-base": "15.0.0",
    "eslint-plugin-import": "2.25.3",
    "eslint-plugin-node": "11.1.0",
    "nodemon": "^2.0.20",
    "sequelize-cli": "6.4.1",
    "socket.io-client": "^4.8.1"
  }
}
